# Next.js server-side Hasura settings
HASURA_GRAPHQL_ENDPOINT=https://model-honeybee-77.hasura.app/v1/graphql
HASURA_ADMIN_SECRET=replace_with_admin_secret

# Contact form: send submission to info@phasematrixmedia.com (Resend)
# Used when Hasura is not set, or as fallback if Hasura insert fails.
RESEND_API_KEY=re_xxxxxxxxxxxx
# Optional: inbox (default: info@phasematrixmedia.com)
# CONTACT_TO_EMAIL=info@phasematrixmedia.com
# Optional: custom "from" (must be a verified domain in Resend); default: onboarding@resend.dev
# CONTACT_FROM_EMAIL=PhaseMatrix <contact@yourdomain.com>

# Optional frontend API endpoint overrides
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:5000/graphql
