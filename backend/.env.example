DATABASE_URL=postgresql://<user>:<password>@<endpoint>/<database>?sslmode=require

# Optional fallback variables if DATABASE_URL is not set
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=phasematrix_blog

# Frontend origin(s) allowed by Flask CORS, comma-separated
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
